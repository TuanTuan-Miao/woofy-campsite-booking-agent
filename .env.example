# Scheduler and booking behavior
AGENT_ENABLED=true
POLL_CRON=*/1 * * * *
HEADLESS=false
BOOKING_ENABLED=true
COMMIT_MODE=cart
MANUAL_VERIFICATION_TIMEOUT_MS=900000

# Recreation.gov credentials
RECREATION_BASE_URL=https://www.recreation.gov
RECREATION_EMAIL=
RECREATION_PASSWORD=

# Optional Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Decision and guardrails
MAX_TOTAL_PRICE=200
ALLOW_ALTERNATIVES=true
PARTY_SIZE=2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Single-target fallback mode
CAMPGROUND_ID=
ARRIVAL_DATE=
NIGHTS=
CAMPSITE_TYPE=
PREFERRED_CAMPSITE_IDS=
EXCLUDED_CAMPSITE_IDS=

# Direct campsite URL mode
PRIMARY_CAMPSITE_NAME=
PRIMARY_CAMPSITE_URL=
ALTERNATIVE_CAMPSITE_URLS=
